{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/flutter/ephemeral": true,
    "**/Flutter/ephemeral": true,
    "**/.symlinks": true,
    "**/.plugin_symlinks": true,
    "**/.dart_tool/**": true,
    "**/.flutter-plugins": true,
    "**/.flutter-plugins-dependencies": true,
    "**/.packages": true,
    "**/build/**": true,
    "**/.idea/**": true,
    ".metadata": true,
    "*.iml": true,
    "*.lock": true,
    "**/android/.kotlin/**": true,
    "**/android/.gradle/**": true,
    "**/android/gradle/**": true,
    "**/android/gradlew.bat": true,
    "**/android/**/*.iml": true,
    "**/android/gradlew": true,
    "**/android/gradle.properties": true,
    "**/android/.gitignore": true,
    "**/android/local.properties": true,
    "devtools_options.yaml": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/.dart_tool": true,
    "**/.dart_tool/**": true,
    "**/build/**": true,
    "**/android/.kotlin/**": true,
    "**/android/.gradle/**": true,
    "**/android/gradle/**": true,
    "**/android/gradlew.bat": true
  },
  "flutterWise.initialized": true,
  "flutterWise.appliedFilesExclude": [
    "**/.dart_tool/**",
    "**/.flutter-plugins",
    "**/.flutter-plugins-dependencies",
    "**/.packages",
    "**/build/**",
    "**/.idea/**",
    ".metadata",
    "*.iml",
    "*.lock",
    "**/android/.kotlin/**",
    "**/android/.gradle/**",
    "**/android/gradle/**",
    "**/android/gradlew.bat",
    "**/android/**/*.iml",
    "**/android/gradlew",
    "**/android/gradle.properties",
    "**/android/.gitignore",
    "**/android/local.properties",
    "devtools_options.yaml"
  ],
  "flutterWise.appliedSearchExclude": [
    "**/.dart_tool/**",
    "**/build/**",
    "**/android/.kotlin/**",
    "**/android/.gradle/**",
    "**/android/gradle/**",
    "**/android/gradlew.bat"
  ],
  "flutterWise.previousIconTheme": "vscode-icons",
  "workbench.iconTheme": "flutter-wise-icons"
}
